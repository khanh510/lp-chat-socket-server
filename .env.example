# Copy this file to .env.
#
# Secrets:
# - Generate one long random secret.
# - Use the same value for JWT_SECRET, WP_SHARED_SECRET, and the WordPress
#   "Socket.io HMAC secret" global setting.
#
# Ports:
# - Host ports are safe defaults for Linux, macOS, Windows, and Laragon.
# - Change host ports only when they conflict on the developer machine.

# Direct Node mode.
PORT=3010

# Docker container port. Usually do not change.
CONTAINER_PORT=3000

# Docker host ports exposed to the developer machine.
CHAT_SERVER_BIND_IP=127.0.0.1
REDIS_BIND_IP=127.0.0.1
CHAT_SERVER_HOST_PORT=3010
CHAT_SERVER_SECONDARY_HOST_PORT=3011
REDIS_HOST_PORT=6380

# Direct Node mode Redis URL. Docker services use redis://redis:6379 internally.
REDIS_URL=redis://127.0.0.1:6380

JWT_SECRET=change-me
WP_SHARED_SECRET=change-me

# Use the WordPress origin in production, e.g. https://example.com.
CORS_ORIGIN=*

PUBLISH_RATE_LIMIT_WINDOW_MS=60000
PUBLISH_RATE_LIMIT_MAX=120
PUBLISH_MAX_CLOCK_SKEW_SECONDS=300

# Optional: when set, /metrics requires Authorization: Bearer <METRICS_TOKEN>.
METRICS_TOKEN=
